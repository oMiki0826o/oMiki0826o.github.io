// config/music.json
//
// Modification():
// - Changed 音源改為 YouTube 串流（youtubeId 欄位），移除本地 audio 路徑
// - Added youtubeId 欄位，值為 YouTube 影片 ID（watch?v= 後面那段）
//
// Description:
// 播放器的播放清單。陣列中每個物件是一首歌。
// type 欄位若為 "youtube"，js/player.js 會使用 YouTube IFrame API
// 播放對應的影片（純音訊模式，影片畫面隱藏）。
// 新增歌曲只要在陣列中複製一個新物件並填入對應的 youtubeId 即可。

[
  {
    // 播放器類型：必須是 "youtube" 才會走 YouTube IFrame API 路徑
    "type": "youtube",

    // YouTube 影片 ID，取自 URL watch?v=XXXXX 中的 XXXXX
    // 對應網址：https://www.youtube.com/watch?v=a-eHtP43yKU
    "youtubeId": "a-eHtP43yKU",

    // 歌曲名稱，顯示在播放器標題
    "title": "神のまにまに",

    // 演出者名稱，顯示在歌曲名稱下方的小字
    "artist": "feat.ミク&リン&GUMI",

    // 封面圖網址（目前播放器介面不顯示封面，保留欄位供未來擴充）
    "cover": ""
  }
]
